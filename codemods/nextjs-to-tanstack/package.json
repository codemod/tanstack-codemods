{
  "name": "@codemod/nextjs-to-tanstack",
  "version": "1.0.0",
  "description": "Migrate a project from the Next.js App Router to TanStack Start",
  "type": "module",
  "scripts": {
    "test": "npm run test:root-layout && npm run test:api-routes && npm run test:pages && npm run test:special-files && npm run test:dynamic-params && npm run test:metadata && npm run test:annotate-async-pages && npm run test:rewrite-next-pages-data && npm run test:repair-route-file-tails && npm run test:rewrite-next-types && npm run test:fonts && npm run test:server-fns && npm run test:link-image && npm run test:next-navigation && npm run test:dynamic-script && npm run test:rewrite-next-internal-modules && npm run test:rewrite-next-i18next-imports && npm run test:rewrite-next-cache && npm run test:rewrite-next-headers && npm run test:rewrite-next-server && npm run test:rewrite-next-server-vitest && npm run test:rewrite-next-og && npm run test:strip-unused-next-imports && npm run test:annotate-next-imports && npm run test:globals-css && npm run test:package-json && npm run test:patch-cjs-esm && npm run test:patch-tooling && npm run test:cleanup-legacy-pages && npm run test:ensure-app-root && npm run test:patch-i18n && npm run test:migration-guide",
    "test:root-layout": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-root-layout.ts ./tests/rewrite-root-layout",
    "test:ensure-app-root": "codemod jssg test -l json --allow-fs ./scripts/entries/ensure-app-root.ts ./tests/ensure-app-root",
    "test:patch-i18n": "codemod jssg test -l json --allow-fs ./scripts/entries/patch-root-i18n-provider.ts ./tests/patch-root-i18n-provider",
    "test:api-routes": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-api-routes.ts ./tests/rewrite-api-routes",
    "test:pages": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-pages.ts ./tests/rewrite-pages",
    "test:special-files": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-special-next-files.ts ./tests/rewrite-special-next-files",
    "test:dynamic-params": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-dynamic-params.ts ./tests/rewrite-dynamic-params",
    "test:metadata": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-metadata.ts ./tests/rewrite-metadata",
    "test:annotate-async-pages": "codemod jssg test -l tsx --allow-fs ./scripts/entries/annotate-async-pages.ts ./tests/annotate-async-pages",
    "test:rewrite-next-pages-data": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-next-pages-data.ts ./tests/rewrite-next-pages-data",
    "test:repair-route-file-tails": "codemod jssg test -l tsx --allow-fs ./scripts/entries/repair-route-file-tails.ts ./tests/repair-route-file-tails",
    "test:rewrite-next-types": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-next-types.ts ./tests/rewrite-next-types",
    "test:annotate-next-imports": "codemod jssg test -l tsx --allow-fs ./scripts/entries/annotate-remaining-next-imports.ts ./tests/annotate-remaining-next-imports",
    "test:fonts": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-fonts.ts ./tests/rewrite-fonts",
    "test:server-fns": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-server-fns.ts ./tests/rewrite-server-fns",
    "test:link-image": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-link-image.ts ./tests/rewrite-link-image",
    "test:next-navigation": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-next-navigation.ts ./tests/rewrite-next-navigation",
    "test:globals-css": "codemod jssg test -l css --allow-fs ./scripts/entries/patch-globals-css.ts ./tests/patch-globals-css",
    "test:package-json": "codemod jssg test -l json --allow-fs ./scripts/entries/patch-package-json.ts ./tests/patch-package-json",
    "test:patch-cjs-esm": "codemod jssg test -l json --allow-fs ./scripts/entries/patch-cjs-root-configs-for-esm.ts ./tests/patch-cjs-root-configs-for-esm",
    "test:migration-guide": "codemod jssg test -l json --allow-fs ./scripts/entries/write-migration-guide.ts ./tests/write-migration-guide",
    "test:dynamic-script": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-next-dynamic-script.ts ./tests/rewrite-next-dynamic-script",
    "test:rewrite-next-internal-modules": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-next-internal-modules.ts ./tests/rewrite-next-internal-modules",
    "test:rewrite-next-i18next-imports": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-next-i18next-imports.ts ./tests/rewrite-next-i18next-imports",
    "test:rewrite-next-cache": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-next-cache.ts ./tests/rewrite-next-cache",
    "test:rewrite-next-headers": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-next-headers.ts ./tests/rewrite-next-headers",
    "test:rewrite-next-server": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-next-server.ts ./tests/rewrite-next-server",
    "test:rewrite-next-server-vitest": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-next-server-vitest.ts ./tests/rewrite-next-server-vitest",
    "test:rewrite-next-og": "codemod jssg test -l tsx --allow-fs ./scripts/entries/rewrite-next-og.ts ./tests/rewrite-next-og",
    "test:strip-unused-next-imports": "codemod jssg test -l tsx --allow-fs ./scripts/entries/strip-unused-next-imports.ts ./tests/strip-unused-next-imports",
    "test:patch-tooling": "codemod jssg test -l json --allow-fs ./scripts/entries/patch-tooling-and-docs.ts ./tests/patch-tooling",
    "test:cleanup-legacy-pages": "codemod jssg test -l json --allow-fs ./scripts/entries/cleanup-legacy-pages-dir.ts ./tests/cleanup-legacy-pages-dir",
    "test:loose": "npm run test -- --strictness loose",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@codemod.com/jssg-types": "latest",
    "@jssg/utils": "latest",
    "@types/node": "latest",
    "typescript": "latest"
  }
}
